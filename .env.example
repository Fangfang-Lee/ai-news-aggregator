# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_news_db
# For Supabase hosted Postgres, you usually need SSL:
# - Option 1: add `?sslmode=require` to DATABASE_URL
# - Option 2: set DATABASE_SSLMODE=require (if DATABASE_URL doesn't already include sslmode)
DATABASE_SSLMODE=prefer

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# CORS
CORS_ORIGINS=["http://localhost:8000", "http://127.0.0.1:8000"]

# RSS Crawler
RSS_FETCH_INTERVAL=3600
MAX_WORKERS=5

# Docker images (optional, for restricted networks)
# Examples:
# PYTHON_IMAGE=dockerproxy.com/library/python:3.11-slim
# POSTGRES_IMAGE=dockerproxy.com/library/postgres:15-alpine
# REDIS_IMAGE=dockerproxy.com/library/redis:7-alpine
PYTHON_IMAGE=
POSTGRES_IMAGE=
REDIS_IMAGE=